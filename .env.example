# GitHub API — create at https://github.com/settings/tokens
# Scopes needed: read:user, public_repo
GITHUB_TOKEN=ghp_your_token_here
GITHUB_USERNAME=your_github_username

# ISR on-demand revalidation secret (random 32-char string)
REVALIDATE_SECRET=your_random_secret_here

# Vercel deploy hook URL (from Vercel project settings > Git > Deploy Hooks)
# Used in GitHub Actions only — store in GitHub repo secrets, NOT here
VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/...

# Contact form endpoint (e.g. Formspree: https://formspree.io/f/your_id)
NEXT_PUBLIC_FORM_ENDPOINT=https://formspree.io/f/your_form_id

# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://yourdomain.dev

# Optional: Google Analytics measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Gemini API key — powers the "Ask AI about Sai" chat widget and JD Matcher.
# Free tier, no credit card required. Create at https://aistudio.google.com/apikey
# (Google AI Studio's free tier — NOT Vertex AI/Google Cloud, which requires billing)
GOOGLE_GENERATIVE_AI_API_KEY=...
